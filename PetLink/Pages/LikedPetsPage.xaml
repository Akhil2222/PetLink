<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetLink.Pages.LikedPetsPage"
             Title="{Binding Title}">

    <VerticalStackLayout VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Spacing="15">

        <Label Margin="75,-200,75,0"
               Text="Your Liked Pets"
               FontAttributes="Bold"
               FontSize="Title"
               TextColor="Blue"/>

        <Grid Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Text="Pet 1"
                   Grid.Row="1"
                   FontSize="Small"
                   HorizontalTextAlignment="Start"
                   TextColor="Black"/>

            <Button Text="Go To Pet Profile"
                    FontAttributes="Bold, Italic"
                    Margin="10"
                    TextColor="White"
                    BackgroundColor="Green"
                    Command="{Binding PetProfilePage}" />
            
        </Grid>
    </VerticalStackLayout>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetLink.Pages.LoginPage">
    
    <VerticalStackLayout>
        <Label Text="{Binding Title}"
               VerticalOptions="Center" 
               HorizontalOptions="Center"
               FontAttributes="Bold"
               FontSize="Title"/>

        <VerticalStackLayout Margin="20, 20, 20, 20">
            <Entry Placeholder = "{Binding UsernameText}"
                   PlaceholderColor = "Blue"
                   TextColor="Crimson"
                   WidthRequest="300"/>

            <Entry Placeholder = "{Binding PasswordText}"
                   PlaceholderColor = "Blue"
                   TextColor="Crimson"
                   WidthRequest="300"/>
        </VerticalStackLayout>
        
        <Button Grid.Row="1"
                Grid.Column="0"
                Text="{Binding Submit}"
                WidthRequest="300"
                Command="{Binding RegisterClickedCommand}"
                Style="{StaticResource TileButton}"/>


    </VerticalStackLayout>
    
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetLink.Pages.MainPage"
             Title="">

    <VerticalStackLayout>
        <Label Text="{Binding Title}"
               FontSize="Large" 
               TextColor="Blue" 
               FontAttributes="Bold"
               Margin="100,50,0,0"/>

        <Grid Padding="16,24,16,16"
          RowSpacing="6"
          ColumnSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Text="{Binding Login}"
                    Command="{Binding LoginClickedCommand}"
                    Style="{StaticResource TileButton}"/>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Text="{Binding Register}"
                    Command="{Binding RegisterClickedCommand}"
                    Style="{StaticResource TileButton}"/>

        </Grid>

    </VerticalStackLayout>
</ContentPage>
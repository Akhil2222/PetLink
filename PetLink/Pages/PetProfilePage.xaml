<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetLink.Pages.PetProfilePage"
             Title="PetProfilePage">
    
    <VerticalStackLayout>

        <Image Source="{Binding ImageSourceURL}"/>
        
        <Label Text="{Binding Species}"
               FontAttributes="Bold"
               FontSize="Medium"
               TextColor="Black"/>

        <Label Text="{Binding Age}"
               FontAttributes="Bold"
               FontSize="Medium"
               TextColor="Black"/>
        
        <Label Text="{Binding Weight}"
               FontAttributes="Bold"
               FontSize="Medium"
               TextColor="Black"/>

    </VerticalStackLayout>
    
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetLink.Pages.PetProfilePage">
    
    <VerticalStackLayout>

        <Label Text="{Binding Name}"
               Margin="0, 0, 10, 0"
               FontAttributes="Bold"
               FontSize="Title"
               TextColor="Black"
               HorizontalOptions="Center"/>

        <Image Source="{Binding ImageSourceURL}"
               WidthRequest="375"
               HeightRequest="300"
               Aspect="Fill"/>
        
        <Label Text="{Binding Species}"
               FontAttributes="Bold"
               FontSize="Medium"
               TextColor="Black"/>

        <Label Text="{Binding Age}"
               FontAttributes="Bold"
               FontSize="Medium"
               TextColor="Black"/>
        
        <Label Text="{Binding Weight}"
               FontAttributes="Bold"
               FontSize="Medium"
               TextColor="Black"/>

        <Slider></Slider>

    </VerticalStackLayout>
    
</ContentPage>
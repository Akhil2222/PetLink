<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetLink.Pages.RegisterPage"
             Title="{Binding Title}">
    <VerticalStackLayout Padding="24,16"
                         Spacing="24">

        <Grid Margin="25,35,29,20"
              RowSpacing="6"
              ColumnSpacing="12">

            <!--Create a 3 rows x 2 columns grid -->
            <Grid.RowDefinitions>
                <!-- row for first pair -->
                <RowDefinition Height="Auto" />
                <!-- row for second pair -->
                <RowDefinition Height="Auto" />
                <!-- row for wide SQLite -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <!-- left column -->
                <ColumnDefinition Width="*" />
                <!-- right column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Row 0 -->
            <Button Grid.Row="0"
                    Grid.Column="0"
                    Text="{Binding AboutYouButton}"
                    Command="{Binding AboutYouClickedCommand}"
                    Style="{StaticResource TileButton}"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>